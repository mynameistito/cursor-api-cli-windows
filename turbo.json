{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".output/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "check": {},
    "knip": {},
    "fix": {
      "cache": false
    },
    "stage:bridge": {
      "outputs": ["bridge/node.exe", "bridge/node_modules/**"]
    },
    "generate-routes": {
      "outputs": ["src/routeTree.gen.ts"]
    }
  }
}
